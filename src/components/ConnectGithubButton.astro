---
import { signIn } from 'next-auth/react';
import { LinkIcon } from 'lucide-react';
import { Button } from './ui/button.astro';

const className = Astro.props.className;
---

<div class={`ml-8 inline-flex items-center justify-center whitespace-nowrap rounded-md px-4 py-2 text-base font-medium text-white shadow-sm ${className}`}>
  <Button size="lg" class="rounded-xl" onClick={() => signIn('github')}>
    Sign in with GitHub
  </Button>
  <LinkIcon class="ml-2 size-5 text-white" aria-hidden="true" />
</div>
